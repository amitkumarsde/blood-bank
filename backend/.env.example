# Local development defaults (XAMPP / php -S)
# For InfinityFree, use the values from your control panel:
#   DB_HOST = sqlNNN.infinityfree.com   (NOT localhost)
#   DB_USER = if0_XXXXXXXX              (the account user, not the DB name)
#   DB_NAME = if0_XXXXXXXX_blood_bank
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blood_bank
DB_USER=root
DB_PASS=

# Use a long, random string in production.
JWT_SECRET=jwt-secret
